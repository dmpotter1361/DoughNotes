PORT=3500
NODE_ENV=development

# Secret used to sign session JWTs. Change this to a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# Where the SQLite DB + local image uploads live. In Docker this is a volume.
# Defaults to server/data if unset.
# DATA_DIR=/data

# Public base URL of the app — used to build the Google OAuth redirect URI and
# Drive links. Use http://localhost:3500 for local dev, or your HTTPS domain.
APP_BASE_URL=http://localhost:3500

# Google Drive integration (optional). Create OAuth credentials at
# console.cloud.google.com (Web application). Leave blank to disable Drive.
# Authorized redirect URI must be:  <APP_BASE_URL>/api/drive/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional AI recipe extraction (improves messy photo/text imports) ---
# Pick ONE backend; leave both blank to use the built-in heuristic parser.
#
# A) Gemini (hosted, free tier) — best for small servers, uses ~no RAM. Get a free
#    key at https://aistudio.google.com/apikey. Recipe text is sent to Google.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
#
# B) Ollama (local, fully private) — needs ~4 GB+ RAM (3B model ≈ 2 GB won't fit on
#    a 2 GB box). The bundled ollama service is reachable at http://ollama:11434.
OLLAMA_URL=
OLLAMA_MODEL=llama3.2:3b
