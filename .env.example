# Copy this to .env before running `docker compose up`.

# Secret used to sign session tokens. Generate a long random string, e.g.:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Host/container port (3500 → a nod to 350°F). Optional; defaults to 3500.
PORT=3500

# Set to true ONLY when the app is served over HTTPS (e.g. behind a reverse
# proxy). Leave false for plain-HTTP access, or logins won't work.
COOKIE_SECURE=false
