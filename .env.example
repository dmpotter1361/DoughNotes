# Copy this to .env before running `docker compose up`.

# Secret used to sign session tokens. Generate a long random string, e.g.:
#   openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string

# Host/container port (3500 → a nod to 350°F). Optional; defaults to 3500.
PORT=3500

# Set to true ONLY when the app is served over HTTPS (e.g. the caddy profile).
# Leave false for plain-HTTP access, or logins won't work.
COOKIE_SECURE=false

# Domain for the optional HTTPS (caddy) profile. Caddy auto-issues a Let's Encrypt
# certificate for this name. Requires ports 80/443 reachable from the internet.
DOMAIN=doughnotes.myhomegames.net

# Public base URL of the app. Builds the Google OAuth redirect URI + Drive links.
#   Local/plain HTTP:  http://localhost:3500
#   Behind HTTPS:      https://doughnotes.myhomegames.net
APP_BASE_URL=http://localhost:3500

# --- Google Drive integration (optional) ---
# Create OAuth credentials at console.cloud.google.com → APIs & Services →
# Credentials → OAuth client ID → Web application. Add this authorized redirect URI:
#   <APP_BASE_URL>/api/drive/callback
# Leave blank to disable Drive (app falls back to local 1 MB image storage).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Optional AI recipe extraction (better photo/social imports) ---
# Pick ONE; leave both blank to use the built-in heuristic parser.
#
# A) Gemini (hosted, free tier) — recommended for small servers (~no RAM). Free key:
#    https://aistudio.google.com/apikey  (recipe text is sent to Google)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
#
# B) Ollama (local, private) — needs ~4 GB+ RAM. Start with `--profile llm`, then
#    `docker compose --profile llm exec ollama ollama pull llama3.2:3b`.
#   OLLAMA_URL=http://ollama:11434
OLLAMA_URL=
OLLAMA_MODEL=llama3.2:3b
